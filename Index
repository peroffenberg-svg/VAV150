<!DOCTYPE html>
<html lang="no">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<meta name="theme-color" content="#1a3a2a">
<title>Akerselva – VAV 150 år</title>

<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:wght@400;500;600&display=swap');

  :root {
    --green:   #1a3a2a;
    --green2:  #2d5c40;
    --gold:    #c9a84c;
    --water:   #4a80a4;
    --light:   #f5f0e8;
    --text:    #1a1a1a;
    --muted:   #6b6b6b;
    --va-red:  #8b1a1a;
    --radius:  12px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    height: 100%;
    font-family: 'DM Sans', sans-serif;
    background: var(--green);
    color: var(--text);
    overflow: hidden;
  }

  /* ── TOP HEADER ── */
  #header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    background: var(--green);
    padding: 10px 16px 8px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-shadow: 0 2px 12px rgba(0,0,0,0.4);
  }
  #header .brand {
    display: flex; align-items: center; gap: 10px;
  }
  #header .logo-circle {
    width: 38px; height: 38px;
    border: 2px solid var(--gold);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  #header .logo-circle span {
    font-family: 'Playfair Display', serif;
    font-size: 13px;
    color: var(--gold);
    line-height: 1;
    text-align: center;
  }
  #header h1 {
    font-family: 'Playfair Display', serif;
    font-size: 16px;
    color: #fff;
    line-height: 1.1;
  }
  #header h1 small {
    display: block;
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    color: var(--gold);
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    font-style: normal;
  }
  #locate-btn {
    background: var(--gold);
    border: none;
    border-radius: 8px;
    padding: 8px 12px;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: var(--green);
    cursor: pointer;
    display: flex; align-items: center; gap: 5px;
  }
  #locate-btn:active { opacity: 0.8; }

  /* ── MAP ── */
  #map {
    position: fixed;
    top: 62px; left: 0; right: 0; bottom: 70px;
    z-index: 1;
  }

  /* ── BOTTOM NAV ── */
  #bottom-nav {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    z-index: 1000;
    background: var(--green);
    border-top: 1px solid rgba(201,168,76,0.3);
    display: flex;
    height: 70px;
  }
  .nav-btn {
    flex: 1;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 4px;
    background: none; border: none;
    color: rgba(255,255,255,0.5);
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 500;
    cursor: pointer;
    transition: color 0.2s;
  }
  .nav-btn.active { color: var(--gold); }
  .nav-btn svg { width: 22px; height: 22px; }

  /* ── POST PANEL (bottom sheet) ── */
  #post-panel {
    position: fixed;
    bottom: 70px; left: 0; right: 0;
    z-index: 900;
    background: var(--light);
    border-radius: var(--radius) var(--radius) 0 0;
    box-shadow: 0 -4px 24px rgba(0,0,0,0.3);
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
    max-height: 65vh;
    overflow-y: auto;
  }
  #post-panel.open { transform: translateY(0); }
  #post-panel .panel-handle {
    width: 36px; height: 4px;
    background: #ccc; border-radius: 2px;
    margin: 10px auto 0;
  }
  #post-panel .panel-content {
    padding: 14px 18px 20px;
  }
  .panel-type-tag {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 4px;
    margin-bottom: 8px;
  }
  .tag-va { background: var(--va-red); color: #fff; }
  .tag-activity { background: var(--green2); color: #fff; }
  .tag-food { background: var(--gold); color: var(--green); }
  .tag-end { background: var(--text); color: #fff; }

  .panel-num {
    float: right;
    width: 40px; height: 40px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Playfair Display', serif;
    font-size: 18px;
    font-weight: 700;
    margin-left: 12px;
  }
  .panel-num.va { background: var(--va-red); color: #fff; }
  .panel-num.activity { background: var(--green2); color: #fff; }
  .panel-num.food { background: var(--gold); color: var(--green); }
  .panel-num.end { background: var(--text); color: #fff; }

  #panel-title {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    line-height: 1.2;
    color: var(--text);
    margin-bottom: 6px;
    clear: none;
  }
  #panel-desc {
    font-size: 14px;
    line-height: 1.6;
    color: var(--muted);
    margin-top: 8px;
    clear: both;
  }
  #panel-close {
    position: absolute;
    top: 14px; right: 16px;
    background: none; border: none;
    font-size: 20px; color: var(--muted);
    cursor: pointer; line-height: 1;
  }

  /* ── POSTLISTE PANEL ── */
  #list-panel {
    position: fixed;
    top: 62px; left: 0; right: 0; bottom: 70px;
    z-index: 800;
    background: var(--light);
    overflow-y: auto;
    display: none;
    padding: 16px;
  }
  #list-panel h2 {
    font-family: 'Playfair Display', serif;
    font-size: 18px;
    margin-bottom: 14px;
    color: var(--green);
  }
  .list-item {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid #e0dbd0;
    cursor: pointer;
  }
  .list-item:active { background: #eee; margin: 0 -16px; padding: 12px 16px; }
  .list-badge {
    width: 36px; height: 36px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Playfair Display', serif;
    font-size: 15px; font-weight: 700;
    flex-shrink: 0;
  }
  .list-badge.va { background: var(--va-red); color: #fff; }
  .list-badge.activity { background: var(--green2); color: #fff; }
  .list-badge.food { background: var(--gold); color: var(--green); }
  .list-badge.end { background: var(--text); color: #fff; }
  .list-info strong { font-size: 15px; display: block; }
  .list-info span { font-size: 12px; color: var(--muted); }
  .list-arrow { margin-left: auto; color: #bbb; font-size: 18px; }

  /* ── INFO PANEL ── */
  #info-panel {
    position: fixed;
    top: 62px; left: 0; right: 0; bottom: 70px;
    z-index: 800;
    background: var(--light);
    overflow-y: auto;
    display: none;
    padding: 20px 18px;
  }
  #info-panel h2 {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    color: var(--green);
    margin-bottom: 4px;
  }
  #info-panel .subtitle {
    font-size: 12px; letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    margin-bottom: 16px;
  }
  #info-panel p { font-size: 14px; line-height: 1.7; color: var(--muted); margin-bottom: 12px; }
  #info-panel .legend-block { margin-top: 20px; }
  #info-panel .legend-block h3 {
    font-family: 'Playfair Display', serif;
    font-size: 16px; margin-bottom: 10px; color: var(--text);
  }
  .leg-row { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; font-size: 13px; }
  .leg-dot { width: 22px; height: 22px; border-radius: 50%; flex-shrink: 0; }
  .leg-dot.va { background: var(--va-red); }
  .leg-dot.activity { background: var(--green2); }
  .leg-dot.food { background: var(--gold); }
  .leg-dot.end { background: var(--text); }

  /* Leaflet custom markers */
  .custom-marker {
    width: 32px; height: 32px;
    border-radius: 50%;
    border: 3px solid #fff;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Playfair Display', serif;
    font-size: 13px; font-weight: 700;
    color: #fff;
    box-shadow: 0 2px 8px rgba(0,0,0,0.35);
    cursor: pointer;
  }
  .custom-marker.va { background: var(--va-red, #8b1a1a); }
  .custom-marker.activity { background: var(--green2, #2d5c40); }
  .custom-marker.food { background: var(--gold, #c9a84c); color: #1a3a2a; }
  .custom-marker.end { background: #1a1a1a; font-size: 9px; }

  .leaflet-container { font-family: 'DM Sans', sans-serif; }
</style>
</head>
<body>

<!-- HEADER -->
<div id="header">
  <div class="brand">
    <div class="logo-circle"><span>VAV<br>150</span></div>
    <h1>Akerselva<small>Jubileumstur 2024</small></h1>
  </div>
  <button id="locate-btn" onclick="locateMe()">
    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5">
      <circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/>
    </svg>
    Min posisjon
  </button>
</div>

<!-- MAP -->
<div id="map"></div>

<!-- POST DETAIL PANEL -->
<div id="post-panel">
  <div class="panel-handle"></div>
  <button id="panel-close" onclick="closePanel()">✕</button>
  <div class="panel-content">
    <span id="panel-num" class="panel-num"></span>
    <span id="panel-tag" class="panel-type-tag"></span>
    <div id="panel-title"></div>
    <div id="panel-desc"></div>
  </div>
</div>

<!-- LIST PANEL -->
<div id="list-panel">
  <h2>Alle poster</h2>
  <div id="list-container"></div>
</div>

<!-- INFO PANEL -->
<div id="info-panel">
  <h2>VAV 150 år</h2>
  <div class="subtitle">Vann- og avløpsetaten · Oslo kommune</div>
  <p>Velkommen til jubileumstur langs Akerselva! Vann- og avløpsetaten fyller 150 år og markerer dette med en vandring fra Sagene til Jakobs kirke — langs den elva som har vært livsnerven i Oslos vannforsyning siden etaten ble stiftet.</p>
  <p>Turen er ca. 4,5 km og tar 1,5–2 timer. Følg de nummererte postene nedover elva. Ved VA-historiske poster får dere innblikk i etater som har formet byens infrastruktur.</p>
  <div class="legend-block">
    <h3>Tegnforklaring</h3>
    <div class="leg-row"><div class="leg-dot va"></div><span>VA-historisk post</span></div>
    <div class="leg-row"><div class="leg-dot activity"></div><span>Aktivitetspost</span></div>
    <div class="leg-row"><div class="leg-dot food"></div><span>Serveringspost</span></div>
    <div class="leg-row"><div class="leg-dot end"></div><span>Endepunkt / mål</span></div>
  </div>
  <p style="margin-top:20px;font-size:12px;">Kart: © OpenStreetMap-bidragsytere</p>
</div>

<!-- BOTTOM NAV -->
<div id="bottom-nav">
  <button class="nav-btn active" id="nav-map" onclick="showView('map')">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polygon points="3,6 9,3 15,6 21,3 21,18 15,21 9,18 3,21"/>
      <line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/>
    </svg>
    Kart
  </button>
  <button class="nav-btn" id="nav-list" onclick="showView('list')">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/>
      <line x1="8" y1="18" x2="21" y2="18"/>
      <circle cx="3" cy="6" r="1" fill="currentColor"/><circle cx="3" cy="12" r="1" fill="currentColor"/>
      <circle cx="3" cy="18" r="1" fill="currentColor"/>
    </svg>
    Postliste
  </button>
  <button class="nav-btn" id="nav-info" onclick="showView('info')">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="12" r="10"/>
      <line x1="12" y1="8" x2="12" y2="8" stroke-width="3" stroke-linecap="round"/>
      <line x1="12" y1="12" x2="12" y2="16"/>
    </svg>
    Om turen
  </button>
</div>

<!-- Leaflet JS -->
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
// ── DATA ──
const posts = [
  {
    id: 1, type: 'va',
    name: 'Sagene vannverk',
    desc: 'Historisk pumpestasjon fra 1860-tallet. Her startet Oslos moderne vannforsyning. VAV hentet vann fra Maridalsvannet og pumpet det ned til byen gjennom ledningsnettet langs elva.',
    lat: 59.9365, lng: 10.7628
  },
  {
    id: 2, type: 'activity',
    name: 'Bentse bru',
    desc: 'Aktivitetspost ved Bentse bru. En av de eldste broene over Akerselva. Her starter aktivitet — [beskriv aktivitet her].',
    lat: 59.9328, lng: 10.7618
  },
  {
    id: 3, type: 'va',
    name: 'Nedre Foss / Damfossen',
    desc: 'Damfossen er et av Akerselvas mest historiske punkter. Fossefall som drev industri og vannmøller i hundrevis av år, og var avgjørende for tidlig vannforsyning nedover i byen.',
    lat: 59.9265, lng: 10.7598
  },
  {
    id: 4, type: 'food',
    name: 'Vulkan / Mathallen',
    desc: 'Serveringspost ved Vulkan. Mathallen Oslo er et av byens mest levende matmiljøer — perfekt sted for en pause halvveis i turen.',
    lat: 59.9218, lng: 10.7572
  },
  {
    id: 5, type: 'activity',
    name: 'Grünerløkka torg',
    desc: 'Aktivitetspost ved Grünerløkka torg. Bydelssenteret i Grünerløkka — [beskriv aktivitet her].',
    lat: 59.9198, lng: 10.7558
  },
  {
    id: 6, type: 'va',
    name: 'Nybrua',
    desc: 'VA-historisk post ved Nybrua. Her løp de første store avløpsledningene for separering av overvann og spillvann i Oslo på slutten av 1800-tallet.',
    lat: 59.9168, lng: 10.7542
  },
  {
    id: 7, type: 'activity',
    name: 'Beierbrua',
    desc: 'Aktivitetspost ved Beierbrua. En av de karakteristiske broene i Grünerløkka-området — [beskriv aktivitet her].',
    lat: 59.9145, lng: 10.7530
  },
  {
    id: 8, type: 'va',
    name: 'Hausmanns pumpestation',
    desc: 'Historisk pumpestation som håndterte avløp fra sentrale bydeler. Et av VAVs viktigste anlegg fra etableringsfasen, og et bevis på tidlig ingeniørkunst i Oslos VA-nett.',
    lat: 59.9115, lng: 10.7515
  },
  {
    id: 9, type: 'activity',
    name: 'Vaterland',
    desc: 'Aktivitetspost i Vaterland-området. Fra industriområde til urbant møtested — [beskriv aktivitet her].',
    lat: 59.9088, lng: 10.7502
  },
  {
    id: 10, type: 'activity',
    name: 'Grønland kvartal',
    desc: 'Aktivitetspost i Grønland. Et av Oslos mest mangfoldige nabolag — [beskriv aktivitet her].',
    lat: 59.9062, lng: 10.7488
  },
  {
    id: 11, type: 'activity',
    name: 'Minneparken / Gamlebyen',
    desc: 'Severdighet ved Minneparken. Her ligger ruinene av middelalderens Oslo, inkludert Olavsklosteret. Akerselva har vært livsnerven i denne bydelen i tusen år.',
    lat: 59.9035, lng: 10.7475
  },
  {
    id: 12, type: 'end',
    name: 'Jakobs kirke — MÅL',
    desc: 'Endepunkt for jubileumsturen! Jakobs kirke markerer avslutningen på vandringen langs Akerselva. Her samles alle til feiring av VAVs 150-årsjubileum. Gratulerer med turen!',
    lat: 59.9008, lng: 10.7460
  }
];

const typeConfig = {
  va:       { label: 'VA-historisk',   cssClass: 'va',       tagClass: 'tag-va' },
  activity: { label: 'Aktivitetspost', cssClass: 'activity', tagClass: 'tag-activity' },
  food:     { label: 'Serveringspost', cssClass: 'food',     tagClass: 'tag-food' },
  end:      { label: 'Endepunkt',      cssClass: 'end',      tagClass: 'tag-end' }
};

// ── MAP INIT ──
const map = L.map('map', {
  center: [59.9190, 10.757],
  zoom: 14,
  zoomControl: false,
  attributionControl: true
});

L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
  attribution: '© <a href="https://openstreetmap.org">OpenStreetMap</a>',
  maxZoom: 19
}).addTo(map);

// Add zoom control top-right
L.control.zoom({ position: 'topright' }).addTo(map);

// ── DRAW ROUTE LINE ──
const routeCoords = posts.map(p => [p.lat, p.lng]);
L.polyline(routeCoords, {
  color: '#4a80a4',
  weight: 4,
  opacity: 0.7,
  dashArray: '8, 6'
}).addTo(map);

// ── MARKERS ──
posts.forEach(post => {
  const cfg = typeConfig[post.type];
  const icon = L.divIcon({
    className: '',
    html: `<div class="custom-marker ${cfg.cssClass}" style="
      width:32px;height:32px;border-radius:50%;border:3px solid #fff;
      display:flex;align-items:center;justify-content:center;
      font-family:'Playfair Display',serif;font-size:${post.id===12?9:13}px;
      font-weight:700;box-shadow:0 2px 8px rgba(0,0,0,.35);cursor:pointer;
      background:${cfg.cssClass==='va'?'#8b1a1a':cfg.cssClass==='activity'?'#2d5c40':cfg.cssClass==='food'?'#c9a84c':'#1a1a1a'};
      color:${cfg.cssClass==='food'?'#1a3a2a':'#fff'};
    ">${post.id===12?'MÅL':post.id}</div>`,
    iconSize: [32, 32],
    iconAnchor: [16, 16],
    popupAnchor: [0, -20]
  });

  L.marker([post.lat, post.lng], { icon })
    .addTo(map)
    .on('click', () => openPanel(post));
});

// ── START/END flags ──
// Start marker label
L.marker([posts[0].lat, posts[0].lng], {
  icon: L.divIcon({
    className: '',
    html: `<div style="background:#1a3a2a;color:#c9a84c;font-size:9px;font-weight:700;
      padding:2px 5px;border-radius:4px;white-space:nowrap;letter-spacing:1px;
      margin-top:-28px;margin-left:16px;box-shadow:0 1px 4px rgba(0,0,0,.3)">START</div>`,
    iconSize: [50, 16], iconAnchor: [0, 0]
  })
}).addTo(map);

// ── PANEL LOGIC ──
function openPanel(post) {
  const cfg = typeConfig[post.type];
  document.getElementById('panel-num').textContent = post.id === 12 ? '✓' : post.id;
  document.getElementById('panel-num').className = `panel-num ${cfg.cssClass}`;
  document.getElementById('panel-tag').textContent = cfg.label;
  document.getElementById('panel-tag').className = `panel-type-tag ${cfg.tagClass}`;
  document.getElementById('panel-title').textContent = post.name;
  document.getElementById('panel-desc').textContent = post.desc;
  document.getElementById('post-panel').classList.add('open');
  map.panTo([post.lat, post.lng], { animate: true });
}

function closePanel() {
  document.getElementById('post-panel').classList.remove('open');
}

// ── LIST VIEW ──
function buildList() {
  const container = document.getElementById('list-container');
  container.innerHTML = '';
  posts.forEach(post => {
    const cfg = typeConfig[post.type];
    const el = document.createElement('div');
    el.className = 'list-item';
    el.innerHTML = `
      <div class="list-badge ${cfg.cssClass}">${post.id === 12 ? '✓' : post.id}</div>
      <div class="list-info">
        <strong>${post.name}</strong>
        <span>${cfg.label}</span>
      </div>
      <span class="list-arrow">›</span>
    `;
    el.onclick = () => {
      showView('map');
      setTimeout(() => openPanel(post), 100);
    };
    container.appendChild(el);
  });
}
buildList();

// ── VIEW SWITCHING ──
function showView(view) {
  document.getElementById('list-panel').style.display = 'none';
  document.getElementById('info-panel').style.display = 'none';
  document.getElementById('map').style.display = 'block';
  closePanel();

  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));

  if (view === 'list') {
    document.getElementById('list-panel').style.display = 'block';
    document.getElementById('nav-list').classList.add('active');
  } else if (view === 'info') {
    document.getElementById('info-panel').style.display = 'block';
    document.getElementById('nav-info').classList.add('active');
  } else {
    document.getElementById('nav-map').classList.add('active');
  }
}

// ── LOCATE ──
function locateMe() {
  if (!navigator.geolocation) { alert('Geolokalisering ikke støttet.'); return; }
  const btn = document.getElementById('locate-btn');
  btn.textContent = '...';
  navigator.geolocation.getCurrentPosition(pos => {
    const { latitude: lat, longitude: lng } = pos.coords;
    map.setView([lat, lng], 16, { animate: true });
    L.circleMarker([lat, lng], {
      radius: 10, fillColor: '#4a80a4', fillOpacity: 0.9,
      color: '#fff', weight: 3
    }).addTo(map).bindPopup('Din posisjon').openPopup();
